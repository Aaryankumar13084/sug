modules = ["nodejs-20"]
run = "node index.js"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot Server"

[[workflows.workflow]]
name = "Telegram Bot Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[deployment]
run = ["sh", "-c", "node index.js"]

[[ports]]
localPort = 8000
externalPort = 8000

[agent]
expertMode = true
