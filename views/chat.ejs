<!DOCTYPE html>
<html lang="hi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sugam Garbh Chat - आपका AI साथी</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/form.css">
    <style>
        body {
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background: var(--warm-cream);
        }

        /* Chat Container */
        .chat-container {
            flex: 1;
            overflow-y: auto;
            padding: 90px 16px 20px;
            display: flex;
            flex-direction: column;
            gap: 16px;
            max-width: 700px;
            margin: 0 auto;
            width: 100%;
            scroll-behavior: smooth;
        }

        /* Messages */
        .message {
            max-width: 82%;
            padding: 14px 18px;
            font-size: 0.92rem;
            line-height: 1.65;
            position: relative;
            animation: msgIn 0.35s ease;
        }

        @keyframes msgIn {
            from {
                opacity: 0;
                transform: translateY(8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .user-message {
            background: var(--primary-pink);
            color: white;
            margin-left: auto;
            border-radius: 20px 20px 6px 20px;
            box-shadow: 0 3px 12px rgba(232, 114, 138, 0.25);
        }

        .bot-message {
            background: white;
            color: var(--text-dark);
            margin-right: auto;
            border-radius: 20px 20px 20px 6px;
            border: 1px solid var(--border-light);
            box-shadow: var(--shadow-sm);
        }

        .bot-label {
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--primary-pink);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .bot-label i {
            font-size: 0.6rem;
        }

        /* Input Area */
        .input-area {
            background: white;
            padding: 16px 20px;
            border-top: 1px solid var(--border-light);
        }

        .input-wrapper {
            max-width: 700px;
            margin: 0 auto;
            position: relative;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .form-control {
            border-radius: 25px;
            padding: 12px 20px;
            border: 1px solid rgba(232, 114, 138, 0.2);
            background: var(--soft-pink-bg);
            transition: var(--transition);
            font-size: 0.92rem;
            flex: 1;
        }

        .form-control:focus {
            background: white;
            border-color: var(--primary-pink);
            box-shadow: 0 0 0 4px rgba(232, 114, 138, 0.1);
        }

        .btn-send {
            background: var(--primary-pink);
            color: white;
            border-radius: 50%;
            width: 44px;
            height: 44px;
            min-width: 44px;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
            box-shadow: 0 3px 10px rgba(232, 114, 138, 0.3);
        }

        .btn-send:hover {
            background: var(--primary-dark);
            transform: scale(1.05);
        }

        /* Typing Indicator */
        .typing-indicator {
            font-size: 0.78rem;
            color: var(--text-light);
            padding: 6px 20px;
            max-width: 700px;
            margin: 0 auto;
            display: none;
            width: 100%;
        }

        .typing-indicator .dots {
            display: inline-flex;
            gap: 3px;
        }

        .typing-indicator .dots span {
            width: 5px;
            height: 5px;
            background: var(--primary-pink);
            border-radius: 50%;
            animation: dotPulse 1.4s infinite;
            opacity: 0.4;
        }

        .typing-indicator .dots span:nth-child(2) {
            animation-delay: 0.2s;
        }

        .typing-indicator .dots span:nth-child(3) {
            animation-delay: 0.4s;
        }

        @keyframes dotPulse {

            0%,
            80%,
            100% {
                opacity: 0.4;
                transform: scale(1);
            }

            40% {
                opacity: 1;
                transform: scale(1.2);
            }
        }

        /* Language Select */
        .lang-select {
            background: var(--soft-pink-bg);
            border: 1px solid var(--border-light);
            border-radius: 20px;
            padding: 4px 12px;
            font-size: 0.8rem;
            color: var(--text-medium);
            cursor: pointer;
            outline: none;
            font-family: 'Poppins', sans-serif;
        }

        .lang-select:focus {
            border-color: var(--primary-pink);
        }

        /* Welcome Card */
        .welcome-card {
            background: linear-gradient(135deg, var(--soft-pink-bg) 0%, white 100%);
            border: 1px solid var(--border-light);
            border-radius: 20px;
            padding: 24px;
            text-align: center;
            margin-bottom: 8px;
        }

        .welcome-icon {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .welcome-card h3 {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 6px;
        }

        .welcome-card p {
            font-size: 0.85rem;
            color: var(--text-medium);
            margin-bottom: 0;
        }

        /* Quick Actions */
        .quick-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: center;
            margin-top: 12px;
        }

        .quick-btn {
            background: white;
            border: 1px solid var(--border-light);
            border-radius: 20px;
            padding: 6px 14px;
            font-size: 0.78rem;
            color: var(--text-medium);
            cursor: pointer;
            transition: var(--transition);
            font-family: 'Poppins', sans-serif;
        }

        .quick-btn:hover {
            background: var(--soft-pink-bg);
            border-color: var(--primary-pink);
            color: var(--primary-pink);
        }

        /* Dark mode overrides for chat */
        [data-theme="dark"] .input-area {
            background: #1e1a1b;
            border-top-color: var(--border-light);
        }

        [data-theme="dark"] .form-control {
            background: #2a2325;
            border-color: rgba(240, 141, 160, 0.15);
            color: var(--text-dark);
        }

        [data-theme="dark"] .form-control:focus {
            background: #1e1a1b;
            border-color: var(--primary-pink);
            color: var(--text-dark);
        }

        [data-theme="dark"] .form-control::placeholder {
            color: var(--text-light);
        }

        [data-theme="dark"] .bot-message {
            background: #1e1a1b;
            border-color: var(--border-light);
            color: var(--text-dark);
        }

        [data-theme="dark"] .user-message {
            box-shadow: 0 3px 12px rgba(0, 0, 0, 0.3);
        }

        [data-theme="dark"] .welcome-card {
            background: linear-gradient(135deg, #1e1a1b 0%, #2a2325 100%);
            border-color: var(--border-light);
        }

        [data-theme="dark"] .quick-btn {
            background: #2a2325;
            border-color: rgba(240, 141, 160, 0.15);
            color: var(--text-medium);
        }

        [data-theme="dark"] .quick-btn:hover {
            background: #352e30;
            border-color: var(--primary-pink);
            color: var(--primary-pink);
        }

        [data-theme="dark"] .lang-select {
            background: #2a2325;
            border-color: rgba(240, 141, 160, 0.15);
            color: var(--text-medium);
        }
    </style>
    <style>
        /* Layout */
        .app-container {
            display: flex;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
            padding-top: 60px;
            /* Space for navbar */
        }

        /* Sidebar Styles */
        .chat-sidebar {
            width: 260px;
            background: var(--card-bg);
            border-right: 1px solid var(--border-light);
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 15px;
            border-bottom: 1px solid var(--border-light);
        }

        .new-chat-btn {
            width: 100%;
            background: var(--soft-pink-bg);
            color: var(--primary-pink);
            border: 1px dashed var(--primary-pink);
            border-radius: var(--radius-sm);
            padding: 10px;
            text-align: left;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .new-chat-btn:hover {
            background: var(--primary-pink);
            color: white;
        }

        .session-list {
            flex: 1;
            overflow-y: auto;
            padding: 10px 0;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .session-item {
            padding: 12px 15px;
            cursor: pointer;
            border-radius: 0;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-dark);
            text-decoration: none;
            position: relative;
        }

        .session-item:hover {
            background: var(--soft-pink-bg);
        }

        .session-item.active {
            background: var(--soft-pink-bg);
            border-left: 3px solid var(--primary-pink);
            font-weight: 600;
        }

        .session-title {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            font-size: 0.9rem;
            flex: 1;
        }

        .session-delete {
            color: var(--text-light);
            opacity: 0;
            transition: opacity 0.2s;
            cursor: pointer;
            background: none;
            border: none;
            padding: 5px;
        }

        .session-item:hover .session-delete {
            opacity: 1;
        }

        .session-delete:hover {
            color: var(--primary-dark);
        }

        /* Main Content */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            position: relative;
            min-width: 0;
        }

        /* Mobile Adjustments */
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 999;
        }

        .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            font-size: 1.2rem;
            color: var(--text-dark);
            margin-right: 10px;
            cursor: pointer;
        }

        @media (max-width: 768px) {
            /* App container and body fixes */
            body {
                height: 100vh;
                height: 100dvh;
            }

            .app-container {
                padding-top: 60px;
                height: 100vh;
                height: 100dvh;
            }

            /* Chat container padding adjustments */
            .chat-container {
                padding-top: 20px;
                padding-bottom: 100px;
                padding-left: 12px;
                padding-right: 12px;
            }

            /* Input area fixed positioning */
            .input-area {
                position: fixed;
                bottom: 0;
                left: 0;
                right: 0;
                z-index: 100;
                padding: 12px 16px;
            }

            /* Input wrapper and form controls optimization */
            .input-wrapper {
                gap: 8px;
                max-width: 100%;
            }

            .form-control {
                font-size: 16px;
                padding: 10px 16px;
            }

            .btn-send {
                width: 40px;
                height: 40px;
                min-width: 40px;
                flex-shrink: 0;
            }

            /* Typing indicator positioning */
            #typing {
                bottom: 70px;
                left: 16px;
                right: 16px;
                position: fixed;
                z-index: 99;
            }

            /* Welcome card mobile styles */
            .welcome-card {
                padding: 20px 16px;
                margin-bottom: 16px;
            }

            .welcome-icon {
                font-size: 2rem;
            }

            .welcome-card h3 {
                font-size: 1rem;
            }

            .welcome-card p {
                font-size: 0.8rem;
            }

            .quick-btn {
                font-size: 0.75rem;
                padding: 5px 12px;
            }

            /* Mobile menu button */
            .mobile-menu-btn {
                display: block;
            }

            /* Sidebar positioning */
            .chat-sidebar {
                position: fixed;
                top: 60px;
                bottom: 0;
                left: 0;
                transform: translateX(-100%);
                z-index: 1001;
            }

            .chat-sidebar.open {
                transform: translateX(0);
            }

            /* Sidebar overlay */
            .sidebar-overlay.show {
                display: block;
            }
        }

        [data-theme="dark"] .chat-sidebar {
            background: #1e1a1b;
            border-color: var(--border-light);
        }

        [data-theme="dark"] .new-chat-btn {
            background: #2a2325;
            color: var(--primary-pink);
        }

        [data-theme="dark"] .session-item {
            color: var(--text-dark);
        }

        [data-theme="dark"] .session-item:hover,
        [data-theme="dark"] .session-item.active {
            background: #2a2325;
        }

        [data-theme="dark"] .mobile-menu-btn {
            color: var(--text-dark);
        }
    </style>
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar fixed-top">
        <div class="container-fluid px-3 px-md-4">
            <div class="d-flex align-items-center">
                <button class="mobile-menu-btn" id="menuBtn">
                    <i class="fas fa-bars"></i>
                </button>
                <a class="navbar-brand fw-bold m-0" href="/" style="font-size: 1.2rem;">
                    <i class="fas fa-heart me-2" style="color: var(--primary-pink);"></i>Sugam Garbh
                </a>
            </div>
            <div class="ms-auto d-flex align-items-center gap-2">
                <button class="theme-toggle" id="themeToggle" title="Dark Mode">
                    <i class="fas fa-moon" id="themeIcon"></i>
                </button>
                <select id="languageSelect" class="lang-select">
                    <option value="hi">हिंदी</option>
                    <option value="en">English</option>
                </select>
            </div>
        </div>
    </nav>

    <div class="app-container">
        <!-- Sidebar Overlay (Mobile) -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- Sidebar -->
        <aside class="chat-sidebar" id="sidebar">
            <div class="sidebar-header">
                <button class="new-chat-btn" id="newChatBtn">
                    <i class="fas fa-plus"></i>
                    <span id="newChatText">नई चैट (New Chat)</span>
                </button>
            </div>
            <div class="session-list" id="sessionList">
                <!-- Sessions will be loaded here -->
            </div>
        </aside>

        <!-- Main Content (Chat Area) -->
        <main class="main-content">
            <div class="chat-container" id="chatBox" style="padding-top: 20px;">
                <!-- Welcome Card -->
                <div id="welcomeCard" class="welcome-card">
                    <div class="welcome-icon">🤱</div>
                    <h3 id="welcomeTitle">सुगम गर्भ में आपका स्वागत है!</h3>
                    <p id="welcomeText">गर्भावस्था से जुड़ा कोई भी सवाल पूछें। घरेलू नुस्खे, आहार, व्यायाम — सब कुछ।</p>
                    <div class="quick-actions" id="quickActions">
                        <button class="quick-btn" onclick="askQuick('पंजीकरण')">पंजीकरण करें</button>
                        <button class="quick-btn" onclick="askQuick('कमर दर्द का उपाय')">कमर दर्द</button>
                        <button class="quick-btn" onclick="askQuick('उल्टी का घरेलू उपाय')">उल्टी</button>
                        <button class="quick-btn" onclick="askQuick('गर्भावस्था में आहार')">आहार</button>
                        <button class="quick-btn" onclick="askQuick('नींद नहीं आती')">नींद</button>
                    </div>
                </div>
            </div>

            <!-- Typing Indicator -->
            <div id="typing" class="typing-indicator" style="position: absolute; bottom: 80px;">
                <span id="typingText">सहायक टाइप कर रही है</span>
                <span class="dots"><span></span><span></span><span></span></span>
            </div>

            <!-- Input Area -->
            <div class="input-area">
                <div class="input-wrapper">
                    <form id="chatForm" style="display: flex; gap: 10px; width: 100%; align-items: center;">
                        <input type="text" id="userInput" class="form-control" placeholder="अपना सवाल पूछें..."
                            autocomplete="off" required>
                        <button type="submit" class="btn-send">
                            <i class="fas fa-paper-plane" style="font-size: 0.9rem;"></i>
                        </button>
                    </form>
                </div>
            </div>
        </main>
    </div>

    <script>
        const PUBLIC_VAPID_KEY = 'BMDnNdEtZZydvv-bMfE0eRn_Y6P2p8IuYePSjKDLLYAzs0Gzk2esxVy8la4Yve5bIy1u0-mbsIiNbsA6WSrvRRo';

        // Persistent Session ID Logic
        let sessionId = localStorage.getItem('sugam-session-id');
        if (!sessionId) {
            sessionId = 'web_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
            localStorage.setItem('sugam-session-id', sessionId);
        }

        const chatForm = document.getElementById('chatForm');
        const userInput = document.getElementById('userInput');
        const chatBox = document.getElementById('chatBox');
        const languageSelect = document.getElementById('languageSelect');
        const typingIndicator = document.getElementById('typing');
        const welcomeCard = document.getElementById('welcomeCard');

        function urlBase64ToUint8Array(base64String) {
            const padding = '='.repeat((4 - base64String.length % 4) % 4);
            const base64 = (base64String + padding).replace(/\-/g, '+').replace(/_/g, '/');
            const rawData = window.atob(base64);
            const outputArray = new Uint8Array(rawData.length);
            for (let i = 0; i < rawData.length; ++i) {
                outputArray[i] = rawData.charCodeAt(i);
            }
            return outputArray;
        }

        async function registerPush() {
            if ('serviceWorker' in navigator) {
                try {
                    const register = await navigator.serviceWorker.register('/sw.js', { scope: '/' });
                    console.log('Service Worker registered');
                    
                    const subscription = await register.pushManager.subscribe({
                        userVisibleOnly: true,
                        applicationServerKey: urlBase64ToUint8Array(PUBLIC_VAPID_KEY)
                    });

                    await fetch('/api/subscribe', {
                        method: 'POST',
                        body: JSON.stringify({ subscription, sessionId }),
                        headers: { 'content-type': 'application/json' }
                    });
                    console.log('User subscribed to push');
                } catch (err) {
                    console.error('Push registration failed:', err);
                }
            }
        }

        // Auto-register push if permission already granted
        if (Notification.permission === 'granted') {
            registerPush();
        } else if (Notification.permission === 'default') {
            // Optional: Request after some interaction or delay
            setTimeout(() => {
                Notification.requestPermission().then(permission => {
                    if (permission === 'granted') registerPush();
                });
            }, 5000);
        }

        (function () {
            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = document.getElementById('themeIcon');
            const html = document.documentElement;

            function setTheme(theme) {
                html.setAttribute('data-theme', theme);
                localStorage.setItem('sugam-theme', theme);
                themeIcon.className = theme === 'dark' ? 'fas fa-sun' : 'fas fa-moon';
            }

            const savedTheme = localStorage.getItem('sugam-theme') || 'light';
            setTheme(savedTheme);

            themeToggle.addEventListener('click', () => {
                const current = html.getAttribute('data-theme');
                setTheme(current === 'dark' ? 'light' : 'dark');
            });
        })();

        function askQuick(text) {
            userInput.value = text;
            chatForm.dispatchEvent(new Event('submit'));
        }

        function addMessage(text, isUser = false) {
            if (welcomeCard) welcomeCard.style.display = 'none';

            const div = document.createElement('div');
            div.className = `message ${isUser ? 'user-message' : 'bot-message'}`;

            if (!isUser) {
                const label = languageSelect.value === 'hi' ? 'सुगम सहायक' : 'Sugam Assistant';
                div.innerHTML = `<div class="bot-label"><i class="fas fa-heart"></i> ${label}</div>${text.replace(/\n/g, '<br>')}`;
            } else {
                div.textContent = text;
            }

            chatBox.appendChild(div);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        async function submitRegistrationForm(event) {
            event.preventDefault();
            const form = event.target;
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            
            data.language = languageSelect.value === 'en' ? 'english' : 'hindi';

            const submitBtn = form.querySelector('button');
            const originalText = submitBtn.textContent;
            submitBtn.disabled = true;
            submitBtn.textContent = languageSelect.value === 'hi' ? 'प्रक्रिया जारी है...' : 'Processing...';

            try {
                const response = await fetch('/api/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ...data, sessionId })
                });

                const result = await response.json();

                if (response.ok) {
                    form.parentElement.innerHTML = `<div class="text-center py-2"><i class="fas fa-check-circle text-success me-2"></i>${result.message}</div>`;
                    registerPush();
                } else {
                    alert(result.error || 'Registration failed');
                    submitBtn.disabled = false;
                    submitBtn.textContent = originalText;
                }
            } catch (err) {
                console.error('Registration Error:', err);
                alert('Connection error. Please try again.');
                submitBtn.disabled = false;
                submitBtn.textContent = originalText;
            }
        }

        let currentChatSessionId = null;

        // Mobile Sidebar Toggle
        const menuBtn = document.getElementById('menuBtn');
        const sidebar = document.getElementById('sidebar');
        const sidebarOverlay = document.getElementById('sidebarOverlay');

        function toggleSidebar() {
            sidebar.classList.toggle('open');
            sidebarOverlay.classList.toggle('show');
        }

        menuBtn.addEventListener('click', toggleSidebar);
        sidebarOverlay.addEventListener('click', toggleSidebar);

        // Session Management
        const newChatBtn = document.getElementById('newChatBtn');
        const sessionList = document.getElementById('sessionList');

        async function loadSessions() {
            try {
                const res = await fetch(`/api/sessions/${sessionId}`);
                const data = await res.json();
                renderSessionList(data.sessions || []);
            } catch (err) {
                console.error("Failed to load sessions:", err);
            }
        }

        function renderSessionList(sessions) {
            sessionList.innerHTML = '';
            sessions.forEach(session => {
                const item = document.createElement('div');
                item.className = `session-item ${session._id === currentChatSessionId ? 'active' : ''}`;
                item.dataset.id = session._id;

                item.innerHTML = `
                    <i class="far fa-comment-alt"></i>
                    <span class="session-title">${session.title}</span>
                    <button class="session-delete" onclick="deleteSession(event, '${session._id}')">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                `;

                item.addEventListener('click', () => loadChatHistory(session._id));
                sessionList.appendChild(item);
            });
        }

        async function deleteSession(event, id) {
            event.stopPropagation();
            if (!confirm(languageSelect.value === 'hi' ? "क्या आप इस चैट को डिलीट करना चाहते हैं?" : "Delete this chat?")) return;

            try {
                await fetch(`/api/sessions/${sessionId}/${id}`, { method: 'DELETE' });
                if (currentChatSessionId === id) {
                    startNewChat();
                } else {
                    loadSessions();
                }
            } catch (err) {
                console.error("Failed to delete session:", err);
            }
        }

        function startNewChat() {
            currentChatSessionId = null;
            chatBox.innerHTML = '';
            // Re-add welcome card
            chatBox.appendChild(welcomeCard);
            welcomeCard.style.display = 'block';
            loadSessions(); // Re-render to clear 'active' class
            if (window.innerWidth <= 768) toggleSidebar();
        }

        newChatBtn.addEventListener('click', startNewChat);

        async function loadChatHistory(id) {
            currentChatSessionId = id;
            if (window.innerWidth <= 768) toggleSidebar();

            chatBox.innerHTML = '';
            try {
                const res = await fetch(`/api/sessions/${sessionId}/${id}`);
                const data = await res.json();
                if (data.session && data.session.messages) {
                    data.session.messages.forEach(msg => {
                        addMessage(msg.text, msg.role === 'user');
                    });
                }
                loadSessions(); // Re-render to set 'active' class
            } catch (err) {
                console.error("Failed to load chat history:", err);
            }
        }

        // Initialize on load
        loadSessions();

        chatForm.onsubmit = async (e) => {
            e.preventDefault();
            const message = userInput.value.trim();
            if (!message) return;

            addMessage(message, true);
            userInput.value = '';
            typingIndicator.style.display = 'flex';

            // Create new session on first message if none exists
            if (!currentChatSessionId) {
                try {
                    const title = message.split(' ').slice(0, 4).join(' ') + (message.split(' ').length > 4 ? '...' : '');
                    const res = await fetch('/api/sessions', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ sessionId, title })
                    });
                    const data = await res.json();
                    if (data.session) {
                        currentChatSessionId = data.session._id;
                        loadSessions(); // Update sidebar with new session
                    }
                } catch (err) {
                    console.error("Failed to create session in DB:", err);
                }
            }

            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        message,
                        language: languageSelect.value,
                        sessionId,
                        chatSessionId: currentChatSessionId
                    })
                });
                const data = await response.json();
                typingIndicator.style.display = 'none';

                if (data.response && (data.response.includes('Registration complete') || data.response.includes('पंजीकरण पूरा हुआ'))) {
                    registerPush();
                }

                const errorMsg = languageSelect.value === 'hi'
                    ? "क्षमा करें, मैं अभी जवाब नहीं दे पा रही हूँ।"
                    : "Sorry, I cannot respond right now.";
                addMessage(data.response || errorMsg);
            } catch (err) {
                typingIndicator.style.display = 'none';
                const errMsg = languageSelect.value === 'hi'
                    ? "त्रुटि: सर्वर से कनेक्ट नहीं हो सका।"
                    : "Error: Could not connect to the server.";
                addMessage(errMsg);
            }
        };

        languageSelect.onchange = () => {
            const isHindi = languageSelect.value === 'hi';
            userInput.placeholder = isHindi ? 'अपना सवाल पूछें...' : 'Ask your question...';
            document.getElementById('typingText').textContent = isHindi ? 'सहायक टाइप कर रही है' : 'Assistant is typing';

            document.getElementById('welcomeTitle').textContent = isHindi
                ? 'सुगम गर्भ में आपका स्वागत है!'
                : 'Welcome to Sugam Garbh!';
            document.getElementById('welcomeText').textContent = isHindi
                ? 'गर्भावस्था से जुड़ा कोई भी सवाल पूछें। घरेलू नुस्खे, आहार, व्यायाम — सब कुछ।'
                : 'Ask any pregnancy-related question. Home remedies, diet, exercise — everything.';

            const qa = document.getElementById('quickActions');
            if (isHindi) {
                qa.innerHTML = `
                    <button class="quick-btn" onclick="askQuick('पंजीकरण')">पंजीकरण करें</button>
                    <button class="quick-btn" onclick="askQuick('कमर दर्द का उपाय')">कमर दर्द</button>
                    <button class="quick-btn" onclick="askQuick('उल्टी का घरेलू उपाय')">उल्टी</button>
                    <button class="quick-btn" onclick="askQuick('गर्भावस्था में आहार')">आहार</button>
                    <button class="quick-btn" onclick="askQuick('नींद नहीं आती')">नींद</button>
                `;
            } else {
                qa.innerHTML = `
                    <button class="quick-btn" onclick="askQuick('register')">Register Now</button>
                    <button class="quick-btn" onclick="askQuick('Back pain remedies')">Back Pain</button>
                    <button class="quick-btn" onclick="askQuick('Home remedy for nausea')">Nausea</button>
                    <button class="quick-btn" onclick="askQuick('Diet during pregnancy')">Diet</button>
                    <button class="quick-btn" onclick="askQuick('Cannot sleep well')">Sleep</button>
                `;
            }
        };
    </script>
</body>

</html>